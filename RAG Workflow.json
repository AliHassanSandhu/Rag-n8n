    },
    {
      "parameters": {
        "jsCode": "const text = $json.text || '';\n\nconst match = text.match(/\"Output\"\\s*:\\s*\"([\\s\\S]*)\"\\s*}/);\n\nlet answer = match ? match[1] : '';\n\nanswer = answer\n  .replace(/\\\\n/g, '\\n')   // convert escaped newlines\n  .replace(/\\\\\"/g, '\"')    // unescape quotes\n  .trim();\n\nreturn [{\n  json: {\n    email: $('Combine Context').first().json.email,\n    query: $('Combine Context').first().json.query,\n    answer,\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
