    {
      "parameters": {
        "jsCode": "return $input.all().map((item, index) => {\n  const row = item.json;\n\n  const question = row.instruction ?? \"\";\n  const answer = row.response ?? \"\";\n\n  const docId = `${row.category}_${row.intent}_${index}`;\n\n  const search_text = [\n    row.category,\n    row.intent,\n    question,\n    answer,\n  ].join(\" \");\n\n  return {\n    json: {\n      // --- Supabase / Postgres ---\n      doc_id: docId,\n      category: row.category,\n      intent: row.intent,\n      instruction: question,\n      response: answer,\n      flags: row.flags,\n      search_text,\n\n      // --- Pinecone ---\n      pageContent: `Category: ${row.category}\\nIntent: ${row.intent}\\nQuestion: ${question}`,\n      metadata: {\n        id: docId,           // same id for RRF later\n        category: row.category,\n        intent: row.intent,\n        instruction: question,\n        response: answer,\n        flags: row.flags,\n      },\n    },\n  };\n});"
      },
