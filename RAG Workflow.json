    {
      "parameters": {
        "jsCode": "const hfItems = $input.all();\n\n// If n8n split the array into many numeric items\nif (hfItems.length > 1) {\n  const vector = hfItems\n    .map(i => (typeof i.json === 'number' ? i.json : Object.values(i.json)[0]))\n    .map(Number);\n  if (vector.length !== 768) {\n    throw new Error(`Split path: expected 768, got ${vector.length}`);\n  }\n  return [{ json: { vector } }];\n}\n\n// Single item: deep-search for the first numeric array of length 768\nconst root = hfItems[0].json;\n\nfunction findVector(node) {\n  if (Array.isArray(node)) {\n    if (node.length === 768 && node.every(n => typeof n === 'number')) {\n      return node;\n    }\n    for (const el of node) {\n      const found = findVector(el);\n      if (found) return found;\n    }\n  } else if (node && typeof node === 'object') {\n    for (const val of Object.values(node)) {\n      const found = findVector(val);\n      if (found) return found;\n    }\n  }\n  return null;\n}\n\nconst vector = findVector(root);\n\nif (!vector) {\n  // Show the actual shape so we can map it\n  throw new Error('No 768-array found. Raw: ' + JSON.stringify(root).slice(0, 300));\n}\n\nreturn [{ json: { vector } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1776,
        -416
      ],
      "id": "5096745d-433a-4616-838d-529ff5a620f3",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// Cohere response (single item)\nconst cohere = $input.first().json;\nconst results = cohere.results ?? [];\n\n// RRF candidates in the SAME order sent to Cohere\nconst candidates = $('Process results from meged node').all();\n\n// Reorder by Cohere relevance, map index → document\nreturn results\n  .sort((a, b) => b.relevance_score - a.relevance_score)\n  .map((r) => ({\n    json: {\n      response:    candidates[r.index].json.response,\n      instruction: candidates[r.index].json.instruction,\n      relevance:   r.relevance_score,\n    },\n  }));"
      },
