    {
      "parameters": {
        "jsCode": "const K = 60;\nconst items = $input.all();\n\n// --- Split the merged input into the two sources ---\nlet pineconeMatches = [];\nconst supabaseRows = [];\n\nfor (const it of items) {\n  const j = it.json;\n  if (Array.isArray(j.matches)) {\n    pineconeMatches = j.matches;        // Pinecone response object\n  } else if (j.id !== undefined) {\n    supabaseRows.push(j);               // Supabase row\n  }\n}\n\n// --- Clean helpers (strip the \"=\" / whitespace artifacts) ---\nconst cleanId  = (v) => String(v ?? '').replace(/[\\t\\n\\r]/g, '').replace(/^=+/, '').trim();\nconst cleanVal = (v) => (typeof v === 'string' ? v.replace(/^=+/, '') : v);\n\nconst scores = new Map();\nconst docs   = new Map();\n\nfunction add(rawId, rank, doc) {\n  const key = cleanId(rawId);\n  if (!key) return;\n  scores.set(key, (scores.get(key) ?? 0) + 1 / (K + rank));\n  if (!docs.has(key)) docs.set(key, doc);\n}\n\n// Pinecone: array order = rank (already sorted by score desc)\npineconeMatches.forEach((m, i) => {\n  const meta = m.metadata ?? {};\n  add(meta.id ?? m.id, i + 1, {\n    response:    cleanVal(meta.response),\n    instruction: cleanVal(meta.instruction),\n    category:    cleanVal(meta.category),\n    intent:      cleanVal(meta.intent),\n  });\n});\n\n// Supabase: already sorted by rank desc\nsupabaseRows.forEach((r, i) => {\n  add(r.id, i + 1, {\n    response:    cleanVal(r.response),\n    instruction: cleanVal(r.instruction),\n    category:    cleanVal(r.category),\n    intent:      cleanVal(r.intent),\n  });\n});\n\n// --- Fuse, sort, return top candidates ---\nreturn [...scores.entries()]\n  .sort((a, b) => b[1] - a[1])\n  .slice(0, 10)\n  .map(([id, score]) => ({\n    json: {\n      id,\n      rrf_score: score,\n      ...docs.get(id),\n    },\n  }));"
      },
      "type": "n8n-nodes-base.code",
